{
  "panels": [
    {
      "type": "gauge",
      "title": "SLO Push (%)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "c7VwfHunk" },
      "targets": [
        {
          "expr": "(\n  sum(increase(notification_push_process_success_total[$__range])) /\n  (\n    sum(increase(notification_push_process_success_total[$__range])) +\n    sum(increase(notification_push_process_error_total[$__range]))\n  )\n) * 100",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "type": "gauge",
      "title": "SLO Email (%)",
